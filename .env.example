# Copy to `.env.local` and fill in values. Never commit secrets.

# --- Database (Prisma) — use one ---
DATABASE_URL=
# PRISMA_DATABASE_URL=
# POSTGRES_URL=
# POSTGRESQL_URI=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-large

# --- Pinecone / RAG ---
PINECONE_API_KEY=
# Preferred: single name for the app and gh-rag ingest
PINECONE_INDEX=repo-chunks
# Legacy alias (same meaning as PINECONE_INDEX):
# PINECONE_INDEX_NAME=

# --- GitHub (ingest / RAG) ---
GITHUB_TOKEN=

# --- Vercel Cron (Bearer token for /api/cron/ingest) ---
CRON_SECRET=

# --- Redis / Upstash / Vercel KV (optional caching) ---
# Vercel KV / Upstash REST (checked first):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Aliases:
# STORAGE_KV_REST_API_URL=
# STORAGE_KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: research, email ---
# PERPLEXITY_API_KEY=
# RESEND_API_KEY=
