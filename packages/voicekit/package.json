{
  "name": "@jchaffin/voicekit",
  "version": "0.3.0",
  "description": "A provider-agnostic React library for building voice-enabled AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.mjs",
      "require": "./dist/adapters/openai.js"
    },
    "./livekit": {
      "types": "./dist/adapters/livekit.d.ts",
      "import": "./dist/adapters/livekit.mjs",
      "require": "./dist/adapters/livekit.js"
    },
    "./deepgram": {
      "types": "./dist/adapters/deepgram.d.ts",
      "import": "./dist/adapters/deepgram.mjs",
      "require": "./dist/adapters/deepgram.js"
    },
    "./elevenlabs": {
      "types": "./dist/adapters/elevenlabs.d.ts",
      "import": "./dist/adapters/elevenlabs.mjs",
      "require": "./dist/adapters/elevenlabs.js"
    },
    "./assemblyai": {
      "types": "./dist/adapters/assemblyai.d.ts",
      "import": "./dist/adapters/assemblyai.mjs",
      "require": "./dist/adapters/assemblyai.js"
    },
    "./pipecat": {
      "types": "./dist/adapters/pipecat.d.ts",
      "import": "./dist/adapters/pipecat.mjs",
      "require": "./dist/adapters/pipecat.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.mjs",
      "require": "./dist/pipeline/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "voice",
    "ai",
    "openai",
    "livekit",
    "deepgram",
    "elevenlabs",
    "assemblyai",
    "pipecat",
    "realtime",
    "react",
    "agent",
    "webrtc",
    "speech",
    "vad",
    "barge-in",
    "stt",
    "tts"
  ],
  "author": "Jacob Chaffin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.0.0 || >=4.0.0"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "livekit-client": {
      "optional": true
    },
    "livekit-server-sdk": {
      "optional": true
    },
    "@deepgram/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openai/agents": ">=0.0.15",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jchaffin/voicekit"
  }
}
